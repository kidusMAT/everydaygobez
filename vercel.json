{
  "builds": [
    {
      "src": "everyday_gobez/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 15,
        "installCommand": "pip install -r requirements.txt",
        "buildCommand": "python manage.py collectstatic --noinput"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "everyday_gobez/wsgi.py"
    }
  ]
}
